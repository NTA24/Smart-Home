# Mặc định cho `npm run dev` — không chứa URL production.
# Đổi giá trị hoặc tạo `.env.development.local` (gitignored) để override.
# Proxy: khi VITE_API_URL=/api, đặt VITE_DEV_PROXY_API_TARGET trỏ tới backend dev/staging.

VITE_API_URL=/api
VITE_CHAT_AI_URL=http://127.0.0.1:1
VITE_THINGSBOARD_URL=http://127.0.0.1:1

# Bỏ comment và điền khi có upstream thật (không dùng host prod cố định trong code)
# VITE_DEV_PROXY_API_TARGET=https://your-dev-api.example
# VITE_DEV_PROXY_CAMERA_TARGET=https://your-dev-camera.example
